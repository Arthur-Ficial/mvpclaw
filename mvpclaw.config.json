{
  "app": {
    "name": "mvpclaw",
    "dataDir": "./data",
    "workspaceDir": "./workspace",
    "defaultTimezone": "Europe/Vienna"
  },
  "database": {
    "url": "file:./data/mvpclaw.sqlite"
  },
  "telegram": {
    "enabled": true,
    "tokenEnv": "TELEGRAM_BOT_TOKEN",
    "mode": "polling",
    "allowedChatIds": [],
    "allowedUserIds": [],
    "replyMode": "dm-and-mentioned-groups",
    "streaming": {
      "enabled": true,
      "editIntervalMs": 1200,
      "maxMessageChars": 3900
    }
  },
  "agent": {
    "provider": "openrouter",
    "timeoutMs": 180000,
    "maxHistoryMessages": 20,
    "maxToolRounds": 8,
    "systemPromptFile": "./prompts/internal-agent/CLAUDE.md"
  },
  "claudeCli": {
    "command": "claude",
    "useOpenRouter": true,
    "outputFormat": "stream-json",
    "allowedTools": [
      "Read",
      "mcp__mvpclaw-tools__*"
    ],
    "env": {
      "ANTHROPIC_BASE_URL": "https://openrouter.ai/api",
      "ANTHROPIC_AUTH_TOKEN": "${OPENROUTER_API_KEY}",
      "ANTHROPIC_API_KEY": ""
    }
  },
  "openrouter": {
    "enabled": true,
    "apiKeyEnv": "OPENROUTER_API_KEY",
    "baseUrl": "https://openrouter.ai/api/v1",
    "defaultModel": "deepseek/deepseek-v4-flash",
    "enableServerTools": false,
    "serverTools": []
  },
  "anthropic": {
    "enabled": true,
    "apiKeyEnv": "ANTHROPIC_API_KEY",
    "webSearch": {
      "enabled": true,
      "maxUses": 5
    }
  },
  "gemini": {
    "enabled": true,
    "apiKeyEnv": "GEMINI_API_KEY",
    "model": "gemini-2.5-flash",
    "tools": {
      "googleSearch": true,
      "urlContext": true
    }
  },
  "mcp": {
    "enabled": true,
    "servers": {},
    "expose": {
      "toolsServer": true,
      "conversationsServer": true
    }
  },
  "skills": {
    "loadAll": true,
    "enabled": [],
    "disabled": [],
    "skillsDir": "./skills",
    "runtimeClaudeSkillsDir": "~/.mvpclaw/workspaces/default/.claude/skills"
  },
  "deploys": {
    "github": { "enabled": true, "defaultVisibility": "private" },
    "vercel": { "enabled": true, "defaultTarget": "preview", "scope": "" }
  },
  "email": {
    "enabled": false,
    "himalayaAccount": "",
    "defaultPageSize": 10,
    "channel": {
      "enabled": false,
      "account": "",
      "ownAddress": "",
      "pollIntervalSec": 120,
      "allowedFrom": []
    }
  },
  "owner": { "name": "", "email": "" },
  "links": [],
  "proactive": {
    "quietHours": {
      "start": "22:00",
      "end": "08:00"
    },
    "maxPerChatPerDay": 3,
    "minGapSeconds": 900
  },
  "idle": {
    "windowMessages": 40,
    "windowTokens": 24000,
    "autoResetAfterSeconds": 0
  },
  "logging": {
    "level": "info",
    "redact": [
      "TELEGRAM_BOT_TOKEN",
      "OPENROUTER_API_KEY",
      "ANTHROPIC_API_KEY",
      "GEMINI_API_KEY"
    ]
  },
  "power": {
    "enabled": true,
    "telegramVideo": true
  }
}
