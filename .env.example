# MVPClaw runtime secrets. NEVER commit — `.env` is gitignored.
#
# Copy this file to `.env` and fill in your values. The install playbook
# (INSTALL.md, Step 7) walks an AI agent through it.

# Telegram bot token from @BotFather (^\d{8,12}:[A-Za-z0-9_-]{30,}$)
TELEGRAM_BOT_TOKEN=

# OpenRouter API key (starts with sk-or-, ≥ 40 chars)
# Used by both the openrouter direct provider AND the claude-cli bridge
# (via ANTHROPIC_BASE_URL injection).
OPENROUTER_API_KEY=

# Optional direct provider keys (only fill in if you enable those tools)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# MVPClaw runtime paths
MVPCLAW_CONFIG=./mvpclaw.config.json
MVPCLAW_DATA_DIR=./data
MVPCLAW_WORKSPACE_DIR=./workspace
NODE_ENV=production
TZ=Europe/Vienna
